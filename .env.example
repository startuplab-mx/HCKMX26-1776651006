# ============================================================
# NAHUAL — Environment Variables
# Copy to .env and fill with real values.
# Loaded by backend/main.py via python-dotenv and by bot/index.js via dotenv.
# ============================================================

# --- Logging ---
LOG_LEVEL=INFO              # backend (Python logging) + bot (pino)

# --- Backend API ---
# Note: API_HOST/API_PORT are passed to uvicorn on the CLI; not read by code.
API_HOST=0.0.0.0
API_PORT=8000

# --- Database ---
DATABASE_PATH=./backend/nahual.db

# --- Anthropic Claude API (Layer 2 — grey zone only) ---
# Leave the placeholder value to disable the LLM layer entirely.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_SECONDS=5
LLM_GREY_ZONE_MIN=0.3
LLM_GREY_ZONE_MAX=0.6

# --- Classifier Override Threshold ---
# Phase 3 or Phase 4 score >= threshold triggers risk_score = 1.0
OVERRIDE_THRESHOLD=0.80

# --- Bot WhatsApp (Baileys) ---
BOT_BACKEND_URL=http://localhost:8000
BOT_SESSION_DIR=./auth_info_baileys

# --- Reports ---
REPORTS_DIR=./backend/reports/generated

# --- CORS (panel + extension) ---
# Use "*" for permissive demo mode (disables credentials per CORS spec).
CORS_ORIGINS=*

# --- Outbound webhooks (alert.escalated, alert.override) ---
# Comma-separated URLs. Leave empty to disable. Failures are logged not raised.
NAHUAL_WEBHOOK_URLS=
# Optional shared secret sent as X-Nahual-Signature header.
NAHUAL_WEBHOOK_SECRET=
